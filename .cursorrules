## ROUTING (App.jsx)

Use React Router v6 with nested routes and layout routes. Implement it exactly like this:

```jsx
import { BrowserRouter, Routes, Route } from 'react-router-dom';

// Layouts
import RootLayout from './layouts/RootLayout';
import LandingLayout from './layouts/LandingLayout';
import SubSiteLayout from './layouts/SubSiteLayout';
import GamerLayout from './layouts/GamerLayout';

// Top-level pages
import Portal from './pages/Portal';
import RealLivesLanding from './pages/RealLivesLanding';
import Login from './pages/Login';
import NotFound from './pages/NotFound';

// License pages
import LicenseHub from './pages/licenses/LicenseHub';
import SchoolLicense from './pages/licenses/SchoolLicense';
import UniversityLicense from './pages/licenses/UniversityLicense';
import HomeschoolerLicense from './pages/licenses/HomeschoolerLicense';
import GamerLicense from './pages/licenses/GamerLicense';

// Registration pages
import SchoolRegister from './pages/register/SchoolRegister';
import UniversityRegister from './pages/register/UniversityRegister';
import HomeschoolerRegister from './pages/register/HomeschoolerRegister';
import GamerRegister from './pages/register/GamerRegister';

// Sub-site pages (import all)
// ...

export default function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route element={<RootLayout />}>

          {/* Portal вЂ” no layout wrapper, standalone */}
          <Route path="/" element={<Portal />} />

          {/* Landing + pre-entry pages (licenses, login, register) share LandingLayout */}
          <Route element={<LandingLayout />}>
            <Route path="/reallives" element={<RealLivesLanding />} />
            <Route path="/reallives/login" element={<Login />} />

            {/* License hub and detail pages */}
            <Route path="/reallives/licenses" element={<LicenseHub />} />
            <Route path="/reallives/licenses/school" element={<SchoolLicense />} />
            <Route path="/reallives/licenses/university" element={<UniversityLicense />} />
            <Route path="/reallives/licenses/homeschooler" element={<HomeschoolerLicense />} />
            <Route path="/reallives/licenses/gamer" element={<GamerLicense />} />

            {/* Registration forms */}
            <Route path="/reallives/register/school" element={<SchoolRegister />} />
            <Route path="/reallives/register/university" element={<UniversityRegister />} />
            <Route path="/reallives/register/homeschooler" element={<HomeschoolerRegister />} />
            <Route path="/reallives/register/gamer" element={<GamerRegister />} />
          </Route>

          {/* Sub-sites */}
          <Route path="/reallives/school" element={<SubSiteLayout siteKey="school" />}>
            <Route index element={<SchoolHome />} />
            <Route path="about" element={<SchoolAbout />} />
            {/* Add all school sub-routes here */}
          </Route>

          <Route path="/reallives/university" element={<SubSiteLayout siteKey="university" />}>
            <Route index element={<UniversityHome />} />
            {/* Add all university sub-routes here */}
          </Route>

          <Route path="/reallives/homeschooler" element={<SubSiteLayout siteKey="homeschooler" />}>
            <Route index element={<HomeschoolerHome />} />
            {/* Add all homeschooler sub-routes here */}
          </Route>

          <Route path="/reallives/gamer" element={<GamerLayout />}>
            <Route index element={<GamerHome />} />
            {/* Add all gamer sub-routes here */}
          </Route>

          {/* 404 */}
          <Route path="*" element={<NotFound />} />

        </Route>
      </Routes>
    </BrowserRouter>
  );
}
```

---

## LAYOUT FILES

### RootLayout.jsx
- Wraps everything
- Contains `<Outlet />` from React Router so child routes render inside it
- Does NOT include a navbar (each sub-site has its own)
- Is the place where the `ThemeProvider` context wraps the whole app (ThemeProvider can alternatively wrap at main.jsx level)

### LandingLayout.jsx
- Used for: `/reallives` (landing), `/reallives/login`, `/reallives/licenses/**`, `/reallives/register/**`
- These pages all exist "before" the user has chosen a sub-site, so they share a pre-entry visual style
- Renders `<LandingFooter />` (the unique landing page footer) вЂ” NOT the dynamic sub-site `<Footer />`
- Does NOT render a sub-site Navbar (the landing page has its own minimal nav or no nav вЂ” match whatever the original has)
- Example:
```jsx
import LandingFooter from '@components/landing/LandingFooter/LandingFooter';

export default function LandingLayout() {
  return (
    <>
      {/* Optional: landing-specific minimal header/nav here */}
      <main>
        <Outlet />
      </main>
      <LandingFooter />
    </>
  );
}
```

### SubSiteLayout.jsx
- Accepts a `siteKey` prop ("school" | "university" | "homeschooler")
- Provides the `siteKey` to all children via `SiteContext`
- Renders the shared `<Navbar />` and dynamic `<Footer />` around `<Outlet />`
- Example:
```jsx
export default function SubSiteLayout({ siteKey }) {
  return (
    <SiteContext.Provider value={{ siteKey }}>
      <Navbar />
      <main>
        <Outlet />
      </main>
      <Footer />
    </SiteContext.Provider>
  );
}
```

### GamerLayout.jsx
- Same structure as SubSiteLayout but with `siteKey="gamer"`
- Uses gamer-specific Navbar variant or applies a gamer-specific CSS class to the shared Navbar
- If the gamer sub-site has a visually different navbar, create `components/gamer/GamerNavbar/` instead of overloading the shared one

